# Copy this file to .env and replace every CHANGE_ME value before deployment.

# Public/internal DNS names.
AUTH_DOMAIN=auth.company.local
AUTH_ADMIN_DOMAIN=auth-admin.company.local
OPENCLAW_DOMAIN=openclaw.company.local

# Nginx listener ports on the host.
# This default avoids existing host nginx services on 80/443. Use 80/443 only when those ports are free.
HTTP_PORT=18081
HTTPS_PORT=18443

# Public browser-facing base URLs. Include HTTPS_PORT here when using non-standard ports.
AUTH_BASE_URL=https://auth.company.local:18443
AUTH_ADMIN_BASE_URL=https://auth-admin.company.local:18443
OPENCLAW_BASE_URL=https://openclaw.company.local:18443

# TLS certificate files mounted from ./certs.
TLS_CERT_FILE=/etc/nginx/certs/openclaw.crt
TLS_KEY_FILE=/etc/nginx/certs/openclaw.key

# Only these client ranges may access auth-admin.company.local.
# Use space-separated CIDRs accepted by nginx "allow" directives in nginx/templates/default.conf.template.
ADMIN_ALLOWED_CIDR=10.0.0.0/8

# Keycloak bootstrap/admin and database credentials.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Must match the secret configured in keycloak/realm-export/company-realm.json.
KEYCLOAK_CLIENT_ID=openclaw-auth-proxy
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_OPENCLAW_AUTH_PROXY_SECRET

# Generate with: openssl rand -hex 16
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME_32_CHAR_COOKIE_SECRET

# OpenClaw upstream as seen from the nginx container.
# For a service running on the Docker host, use http://host.docker.internal:18789 on Docker Desktop
# or add an extra_hosts host-gateway mapping on Linux and keep this value.
OPENCLAW_UPSTREAM=http://host.docker.internal:18789

# JeecgBoot backend upstream as seen from the nginx container.
JEECG_BACKEND_UPSTREAM=http://host.docker.internal:8081

# Keep false in production. Use true only for short lab validation with untrusted/self-signed cert chains.
OAUTH2_PROXY_SSL_INSECURE_SKIP_VERIFY=false
